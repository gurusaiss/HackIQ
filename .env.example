# ─── AI Keys (TWO WAYS to configure) ─────────────────────────────────────────
#
# OPTION A — Secure (recommended for production / Vercel deploy):
#   Use keys WITHOUT the VITE_ prefix.
#   They live only in Node / the Vite dev-proxy / Vercel serverless functions.
#   They are NEVER embedded in the browser bundle.
#
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...
#
# OPTION B — Quick dev / demo (keys exposed in browser bundle, localhost only):
#   Groq supports browser CORS, so this works fine for local demos.
#   Do NOT commit these to a public repo.
#
# VITE_GROQ_API_KEY=gsk_...
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase (optional — falls back to localStorage) ─────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Config
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Firestore security rules (paste in Firebase Console → Firestore → Rules) ─
# rules_version = '2';
# service cloud.firestore {
#   match /databases/{database}/documents {
#     match /{document=**} {
#       allow read, write: if true;
#     }
#   }
# }
